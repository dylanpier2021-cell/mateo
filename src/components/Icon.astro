const body = ICONS[name] ?? '';
const a11y = title
  ? { role: 'img' as const, 'aria-label': title }
  : { 'aria-hidden': 'true' as const, focusable: 'false' as const };
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  {...a11y}
  set:html={body}
></svg>

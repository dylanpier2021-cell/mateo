---
/**
 * <Icon /> — dependency-free line-icon set (Lucide-style, 24×24, currentColor).
 * Inherits the current text color, so `text-[color:var(--color-grass)]` tints it.
 *
 *   <Icon name="leaf" class="text-[color:var(--color-grass)]" />
 *
 * Decorative by default (aria-hidden). Pass `title` when the icon carries
 * meaning on its own and needs to be exposed to assistive tech.
 */
interface Props {
  name: string;
  size?: number | string;
  class?: string;
  stroke?: number;
  /** Accessible label; when set, the icon is exposed to AT instead of hidden. */
  title?: string;
}

const { name, size = 24, class: className = '', stroke = 2, title } = Astro.props;

const ICONS: Record<string, string> = {

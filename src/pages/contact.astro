---
/**
 * Contact Us — NAP, embedded map, and the contact form.
 *
 * 🚨 The form here is the SAME <LeadForm /> component used by
 * /get-a-free-quote, so its fields and consent section are identical by
 * construction — a hard A2P requirement. Do not hand-roll a second form on this
 * page; edit LeadForm / ConsentFields instead.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import LeadForm from '@components/LeadForm.astro';
import Icon from '@components/Icon.astro';
import {
  BUSINESS,
  SERVICE_AREA_NAMES,
  telHref,
  mailHref,
  mapsHref,
  mapEmbedSrc,
  addressOneLine,
  serviceAreaLine,
} from '@data/business';
---

<BaseLayout
  title={`Contact Us — Champaign, IL Landscaping | ${BUSINESS.legalName}`}
  description={`Contact Mateo Landscaping and More LLC in Champaign, Illinois. Call ${BUSINESS.phoneDisplay}, email ${BUSINESS.email}, or send us a message. Serving Champaign, Urbana, Savoy and Mahomet.`}
  path="/contact"
>
  <section class="bg-[color:var(--color-forest)] text-white">
    <div class="container-page py-14 sm:py-18">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex items-center gap-1.5 text-xs text-white/60">
          <li><a href="/" class="hover:text-white hover:underline">Home</a></li>
          <li aria-hidden="true" class="flex items-center"><Icon name="chevron-right" size={13} /></li>
          <li aria-current="page" class="font-semibold text-[color:var(--color-forest-300)]">Contact</li>
        </ol>
      </nav>

      <p class="eyebrow !text-[color:var(--color-forest-300)]">Contact us</p>
      <h1 class="mt-2 max-w-3xl text-4xl font-black !text-white sm:text-5xl">Get in touch</h1>
      <p class="mt-5 max-w-2xl text-lg text-white/80">
        Call, email, or send us a message — whichever suits you. A real person will get back to you,
        usually the same day. <span class="italic">Hablamos español.</span>
      </p>
    </div>
  </section>

  {/* ===================== DETAILS + FORM ===================== */}
  <section class="py-16 sm:py-20">
    <div class="container-page">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:gap-16">
        {/* Left: NAP + map */}
        <div data-reveal="left">
          <h2 class="text-2xl font-black sm:text-3xl">Our details</h2>
          <p class="mt-3 text-[color:var(--color-charcoal-600)]">
            {BUSINESS.legalName} — family-owned and based right here in {BUSINESS.homeCity}.
          </p>

          <dl class="mt-8 space-y-6">
            <div class="flex items-start gap-4">
              <span class="mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-[color:var(--color-sand-100)] text-[color:var(--color-grass)]">
                <Icon name="map-pin" size={19} />
              </span>
              <div>
                <dt class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--color-grass)]">Address</dt>
                <dd class="mt-1">
                  <a href={mapsHref} target="_blank" rel="noopener" class="font-semibold text-[color:var(--color-forest)] hover:underline">
                    {addressOneLine}
                  </a>
                </dd>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <span class="mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-[color:var(--color-sand-100)] text-[color:var(--color-grass)]">
                <Icon name="phone" size={19} />
              </span>
              <div>
                <dt class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--color-grass)]">Phone</dt>
                <dd class="mt-1">
                  <a href={telHref} class="text-lg font-black text-[color:var(--color-forest)] hover:underline">
                    {BUSINESS.phoneDisplay}
                  </a>
                </dd>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <span class="mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-[color:var(--color-sand-100)] text-[color:var(--color-grass)]">
                <Icon name="mail" size={19} />
              </span>
              <div>
                <dt class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--color-grass)]">Email</dt>
                <dd class="mt-1">
                  <a href={mailHref} class="font-semibold text-[color:var(--color-forest)] hover:underline">
                    {BUSINESS.email}
                  </a>
                </dd>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <span class="mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-[color:var(--color-sand-100)] text-[color:var(--color-grass)]">
                <Icon name="clock" size={19} />
              </span>
              <div>
                <dt class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--color-grass)]">Hours</dt>
                <dd class="mt-1 font-semibold text-[color:var(--color-forest)]">{BUSINESS.hours.display}</dd>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <span class="mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-[color:var(--color-sand-100)] text-[color:var(--color-grass)]">
                <Icon name="map-pin" size={19} />
              </span>
              <div>
                <dt class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--color-grass)]">Service area</dt>
                <dd class="mt-1 text-[color:var(--color-charcoal-600)]">{serviceAreaLine}</dd>
                <dd class="mt-3 flex flex-wrap gap-1.5">
                  {
                    SERVICE_AREA_NAMES.map((city) => (
                      <span class="rounded-full border border-[color:var(--color-line)] bg-[color:var(--color-sand-100)] px-2.5 py-1 text-xs font-semibold text-[color:var(--color-forest)]">
                        {city}
                      </span>
                    ))
                  }
                </dd>
              </div>
            </div>
          </dl>

          {/* Embedded map — keyless Google embed, lazy-loaded */}
          <div class="mt-10 overflow-hidden rounded-md border border-[color:var(--color-line)]">
            <iframe
              src={mapEmbedSrc}
              title={`Map showing the service area of ${BUSINESS.legalName} in ${BUSINESS.homeCity}, ${BUSINESS.homeState}`}
              width="100%"
              height="340"
              style="border:0; display:block;"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen></iframe>
          </div>
        </div>

        {/* Right: the form */}
        <div data-reveal="right">
          <div class="card p-6 sm:p-8">
            <h2 class="text-2xl font-black">Send us a message</h2>
            <p class="mt-2 text-sm text-[color:var(--color-charcoal-600)]">
              Tell us what you need and we'll get back to you — usually the same day.
            </p>

            <div class="mt-6">
              <LeadForm formName="contact" submitLabel="Send message" idPrefix="contact" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

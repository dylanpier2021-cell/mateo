---
/**
 * Feedback — the private feedback form for 1–3★ ratings from /review-us.
 *
 * This is NOT an SMS opt-in form, so it deliberately has NO consent checkboxes.
 * It reuses the shared submit script (data-lead-form → form.ts): it POSTs to the
 * GoHighLevel webhook when configured, otherwise falls back to Netlify Forms,
 * then redirects to /thank-you. Feedback here is private — it is never published.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Icon from '@components/Icon.astro';
import { BUSINESS, LEAD, telHref, mailHref } from '@data/business';

const inputCls = 'field';
---

<BaseLayout
  title={`Share Your Feedback | ${BUSINESS.legalName}`}
  description="Tell Mateo Landscaping and More LLC how we can do better. Your feedback is private and goes straight to the owner."
  path="/feedback"
  noindex={true}
>
  <section class="bg-[color:var(--color-forest)] text-white">
    <div class="container-page py-14 sm:py-18">
      <p class="eyebrow !text-[color:var(--color-forest-300)]">Private feedback</p>
      <h1 class="mt-3 max-w-3xl text-4xl font-black !text-white sm:text-5xl">
        Tell us how we can make it right
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-white/80">
        Thank you for being honest with us. This goes straight to {BUSINESS.owner} and the team —
        it's private, it isn't posted publicly, and we read every word.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="container-page">
      <div class="mx-auto max-w-2xl">
        <div class="card p-6 sm:p-8">
          <form
            class="grid gap-5"
            data-lead-form
            data-webhook={LEAD.inboundWebhookUrl}
            data-thanks={LEAD.thankYouPath}
            name="feedback"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action={LEAD.thankYouPath}
            aria-describedby="feedback-status"
          >
            {/* Netlify Forms wiring + source tag (no SMS consent — not an opt-in) */}
            <input type="hidden" name="form-name" value="feedback" />
            <input type="hidden" name="source_form" value="feedback" />
            <p class="hidden" aria-hidden="true">
              <label>Leave this field empty: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
            </p>

            <div>
              <label class="field-label" for="fb-message">What could we have done better?</label>
              <textarea
                class={inputCls}
                id="fb-message"
                name="message"
                rows="5"
                required
                placeholder="Tell us what happened and how we can make it right."></textarea>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label class="field-label" for="fb-name">
                  Name <span class="font-normal text-[color:var(--color-slate-soft)]">(optional)</span>
                </label>
                <input class={inputCls} id="fb-name" name="name" type="text" autocomplete="name" placeholder="Your name" />
              </div>
              <div>
                <label class="field-label" for="fb-phone">
                  Phone <span class="font-normal text-[color:var(--color-slate-soft)]">(optional)</span>
                </label>
                <input class={inputCls} id="fb-phone" name="phone" type="tel" autocomplete="tel" placeholder="So we can follow up" />
              </div>
            </div>

            <div>
              <label class="field-label" for="fb-email">
                Email <span class="font-normal text-[color:var(--color-slate-soft)]">(optional)</span>
              </label>
              <input class={inputCls} id="fb-email" name="email" type="email" autocomplete="email" placeholder="you@email.com" />
            </div>

            <button type="submit" class="btn-cta w-full text-base" data-lead-submit>
              <Icon name="send" size={18} />
              <span data-lead-label>Send private feedback</span>
            </button>

            <p id="feedback-status" role="status" aria-live="polite" class="hidden text-center text-sm"></p>

            <p class="text-center text-xs text-[color:var(--color-slate-soft)]">
              Prefer to talk it through? Call
              <a href={telHref} class="underline hover:text-[color:var(--color-grass-600)]">{BUSINESS.phoneDisplay}</a>
              or email
              <a href={mailHref} class="underline hover:text-[color:var(--color-grass-600)]">{BUSINESS.email}</a>.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
/**
 * Get a Free Quote — the PRIMARY A2P OPT-IN PAGE.
 *
 * 🚨 This exact URL (/get-a-free-quote) is what gets submitted to the carrier as
 * the opt-in URL:
 *     https://www.mateoslandscapingandmore.com/get-a-free-quote
 * Do not rename this file, and do not change the route. If it ever moves, the
 * A2P registration has to be updated to match or the campaign fails review.
 *
 * The form and its consent block come from <LeadForm /> / <ConsentFields />,
 * which /contact also uses — that is what keeps the two identical.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import LeadForm from '@components/LeadForm.astro';
import Icon from '@components/Icon.astro';
import {
  BUSINESS,
  SERVICES,
  telHref,
  mailHref,
  addressOneLine,
  serviceAreaLine,
  PRICING_NOTE,
} from '@data/business';

const STEPS = [
  { n: '1', title: 'Tell us about the job', body: 'Fill out the form, or just call. A sentence or two is plenty to start.' },
  { n: '2', title: 'We come look at it', body: "We walk the property with you — free, and there's no obligation at the end of it." },
  { n: '3', title: 'You get a real number', body: 'A straight price for the actual work. No pressure, no bait-and-switch.' },
];
---

<BaseLayout
  title={`Get a Free Quote — Landscaping & Home Services | ${BUSINESS.legalName}`}
  description="Request a free, no-obligation estimate from Mateo Landscaping and More LLC. Landscaping, fencing, decks and handyman services in Champaign, Urbana, Savoy and Mahomet, IL."
  path="/get-a-free-quote"
>
  <section class="bg-[color:var(--color-forest)] text-white">
    <div class="container-page py-14 sm:py-18">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex items-center gap-1.5 text-xs text-white/60">
          <li><a href="/" class="hover:text-white hover:underline">Home</a></li>
          <li aria-hidden="true" class="flex items-center"><Icon name="chevron-right" size={13} /></li>
          <li aria-current="page" class="font-semibold text-[color:var(--color-forest-300)]">Get a Free Quote</li>
        </ol>
      </nav>

      <div class="grid gap-12 lg:grid-cols-[1fr_1.05fr] lg:gap-16">
        {/* Left: the pitch */}
        <div>
          <p class="eyebrow !text-[color:var(--color-forest-300)]">Free · No obligation</p>
          <h1 class="mt-3 text-4xl font-black !text-white sm:text-5xl">Get a free quote</h1>
          <p class="mt-5 text-lg text-white/80">
            Tell us what you need and we'll come out, look at the actual job, and give you a straight
            number. It costs nothing, and there's no obligation at the end of it.
          </p>

          <ol class="mt-10 space-y-6">
            {
              STEPS.map((step) => (
                <li class="flex gap-4">
                  <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[color:var(--color-grass)] font-black text-white">
                    {step.n}
                  </span>
                  <span>
                    <span class="block font-bold text-white">{step.title}</span>
                    <span class="block text-sm text-white/70">{step.body}</span>
                  </span>
                </li>
              ))
            }
          </ol>

          <hr class="my-8 border-0 border-t border-white/15" />

          <h2 class="text-sm font-bold uppercase tracking-[0.14em] text-[color:var(--color-forest-300)]">
            What we can quote
          </h2>
          <ul class="check-list check-list--light mt-4 grid gap-x-6 sm:grid-cols-2">
            {SERVICES.map((s) => <li>{s.name}</li>)}
          </ul>

          <div class="mt-8 space-y-2.5 text-sm">
            <p class="flex items-center gap-2.5">
              <span class="text-[color:var(--color-forest-300)]"><Icon name="phone" size={16} /></span>
              <span>
                Prefer to talk?{' '}
                <a href={telHref} class="font-bold text-white underline">{BUSINESS.phoneDisplay}</a>
              </span>
            </p>
            <p class="flex items-center gap-2.5">
              <span class="text-[color:var(--color-forest-300)]"><Icon name="mail" size={16} /></span>
              <a href={mailHref} class="text-white/85 underline">{BUSINESS.email}</a>
            </p>
            <p class="flex items-start gap-2.5">
              <span class="mt-0.5 text-[color:var(--color-forest-300)]"><Icon name="map-pin" size={16} /></span>
              <span class="text-white/70">{addressOneLine}</span>
            </p>
          </div>
        </div>

        {/* Right: the form */}
        <div>
          <div class="rounded-lg bg-white p-6 shadow-2xl sm:p-8">
            <h2 class="text-2xl font-black">Request your free estimate</h2>
            <p class="mt-2 text-sm text-[color:var(--color-charcoal-600)]">
              {PRICING_NOTE} We usually reply the same day.
            </p>

            <div class="mt-6">
              <LeadForm formName="quote" submitLabel="Get my free estimate" idPrefix="quote" />
            </div>
          </div>

          <p class="mt-4 text-center text-xs text-white/60">{serviceAreaLine}</p>
        </div>
      </div>
    </div>
  </section>

  {/* ===================== REASSURANCE ===================== */}
  <section class="py-16">
    <div class="container-page">
      <div class="grid gap-6 sm:grid-cols-3">
        {
          [
            { icon: 'receipt', title: 'Free estimates', body: 'No charge to have us come out and look. No obligation to hire us afterwards.' },
            { icon: 'shield-check', title: 'Warrantied work', body: "We stand behind what we build. If it isn't right, we come back and fix it." },
            { icon: 'languages', title: 'English & Español', body: 'Bilingual from the first call to the last invoice. Hablamos español.' },
          ].map((item, i) => (
            <div class="card p-6" data-reveal style={`--reveal-delay:${i * 80}ms`}>
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-md bg-[color:var(--color-sand-100)] text-[color:var(--color-grass)]">
                <Icon name={item.icon} size={21} />
              </span>
              <h2 class="mt-4 text-lg font-black">{item.title}</h2>
              <p class="mt-2 text-[color:var(--color-charcoal-600)]">{item.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

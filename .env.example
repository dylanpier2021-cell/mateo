# ---------------------------------------------------------------------------
# Mateo Landscaping and More LLC — environment variables
# Copy to `.env` for local dev, and set the same values in Netlify →
# Site settings → Environment variables for production.
# ---------------------------------------------------------------------------

# GoHighLevel Inbound Webhook URL.
# Both the Contact form and the Quote form POST their lead + consent payload
# here. Create it in GHL: Automation → Workflows → Add New Workflow →
# Trigger: "Inbound Webhook" → copy the URL.
#
# If this is left unset the forms fall back to Netlify Forms automatically, so
# leads (and their consent flags) are still captured either way.
PUBLIC_GHL_INBOUND_WEBHOOK_URL=""
